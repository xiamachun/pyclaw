*.md
!README.md

# Docs (generated articles)
docs/

# Config files (contain secrets, only commit .sample)
pyclaw.json

# Build / generated
features.json
Makefile
pyproject.toml
node_modules/
*.pptx
python/script/env/
pyclawwoker/
tests/