# All dot-files/dirs (IDE, cache, env, etc.)
.*
!.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
venv/

# Data / logs
*.db
*.sqlite
*.log

