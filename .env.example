# ============================================================
# PyClaw Configuration (.env)
# Copy this file to ~/.pyclaw/.env and customize as needed.
# ============================================================

# --- Gateway ---
PYCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
PYCLAW_GATEWAY_HOST=127.0.0.1
PYCLAW_GATEWAY_PORT=18789

# --- Paths ---
# State directory (default: ~/.pyclaw)
# PYCLAW_STATE_DIR=~/.pyclaw
# Configuration file path (default: ~/.pyclaw/pyclaw.json)
# PYCLAW_CONFIG_PATH=~/.pyclaw/pyclaw.json
# Workspace directory (default: ~/.pyclaw/workspace)
# PYCLAW_WORKSPACE=~/.pyclaw/workspace
# Log directory (default: ~/.pyclaw/logs)
# PYCLAW_LOG_DIR=~/.pyclaw/logs
# Memory database path (default: ~/.pyclaw/state/memory.sqlite)
# PYCLAW_MEMORY_DB=~/.pyclaw/state/memory.sqlite

# --- LLM Providers ---
# Local LLM URL (Ollama, vLLM, etc.) — recommended for getting started
# PYCLAW_LOCAL_LLM_URL=http://localhost:11434/v1
# Default local model name
# PYCLAW_DEFAULT_LOCAL_MODEL=qwen3.5:9B

# Internal / Remote LLM API (OpenAI-compatible)
# INTERNAL_API_KEY=sk-...
# INTERNAL_BASE_URL=https://your-api-endpoint/v1

# OpenAI API key (for embeddings, etc.)
# OPENAI_API_KEY=sk-...

# --- DingTalk Channel ---
# DINGTALK_APP_KEY=
# DINGTALK_APP_SECRET=
# Gateway URL for DingTalk Stream Client
# PYCLAW_GATEWAY_URL=http://127.0.0.1:18789

# --- Python Environment ---
# Python interpreter path (for restart scripts)
# PYCLAW_PYTHON=python3

# --- Logging ---
PYCLAW_LOG_LEVEL=INFO

# --- Sandbox ---
# PYCLAW_SANDBOX_MODE=docker
